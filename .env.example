# ==============================================
# Automated FIFA Commentary - Environment Config
# ==============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# OpenAI Configuration (Required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model Paths (Optional - defaults shown)
YOLO_MODEL_PATH=models/yolov8n.pt
CLASSIFIER_MODEL_PATH=models/video_classifier.pth

# TTS Configuration (Optional - defaults shown)
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
TTS_SPEED=1.0

# Commentary Configuration (Optional - defaults shown)
OPENAI_COMMENTARY_MODEL=gpt-3.5-turbo
MAX_TOKENS=60
TEMPERATURE=0.7

# Processing Configuration (Optional - defaults shown)
BATCH_SIZE=8
CONFIDENCE_THRESHOLD=0.5
